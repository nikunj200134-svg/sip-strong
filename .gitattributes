# .gitattributes
# This file helps ensure consistent line endings across different operating systems

# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.zip binary
*.tar binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Documentation
*.md text eol=lf diff=markdown

# Configuration files
.env* text eol=lf
.gitignore text eol=lf
.prettierignore text eol=lf
.eslintignore text eol=lf
